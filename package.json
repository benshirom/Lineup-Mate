    "@netlify/plugin-nextjs": "^5.8.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "25.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.25",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
