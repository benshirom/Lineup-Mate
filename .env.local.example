NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only variables. Never expose these with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
CLASHFINDER_AUTH_USERNAME=
CLASHFINDER_PRIVATE_KEY=

# Production URL (used for OAuth redirects in Capacitor and SSR)
NEXT_PUBLIC_APP_URL=https://your-production-url.netlify.app

# Web Push / VAPID keys (generate with: npm run generate:vapid)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@lineupmate.app

# Cron job secret
CRON_SECRET=

# Apple Sign In (Capacitor iOS only)
NEXT_PUBLIC_APPLE_CLIENT_ID=com.lineupmate.app

# Cloudinary (required for avatar uploads)
# Create a free account at https://cloudinary.com, then find these in the dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Upstash Redis (required for rate limiting in production)
# Create a Redis database at https://upstash.com and copy the REST URL and token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
